APP_ENV=development
HTTP_ADDRESS=:8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_SHUTDOWN_TIMEOUT=20s

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/evolution_saas?sslmode=disable
DATABASE_MAX_OPEN_CONNS=20
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=30m

JWT_SECRET=change-me
JWT_TTL=24h
JWT_REFRESH_TTL=168h

BROADCAST_WORKERS=4
BROADCAST_QUEUE_BATCH_SIZE=8
BROADCAST_RATE_PER_SECOND=2
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_MESSAGES_PER_MINUTE=60
RATE_LIMIT_BROADCAST_PER_HOUR=120
RATE_LIMIT_WEBHOOK_CALLS_PER_MINUTE=120

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
AI_TIMEOUT=15s
AI_WORKERS=2
AI_MEMORY_LIMIT=12

POSTGRES_AUTH_DB=postgresql://postgres:postgres@postgres:5432/evogo_auth?sslmode=disable
POSTGRES_USERS_DB=postgresql://postgres:postgres@postgres:5432/evogo_users?sslmode=disable
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=evogo_users
GLOBAL_API_KEY=change-me
CLIENT_NAME=evolution
OS_NAME=Linux
CONNECT_ON_STARTUP=false
WEBHOOK_FILES=true
WEBHOOK_URL=
DEBUG_ENABLED=false
LOG_TYPE=console
LOG_DIRECTORY=/app/logs
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=5
LOG_MAX_AGE=30
LOG_COMPRESS=true

AMQP_URL=
AMQP_GLOBAL_ENABLED=false
AMQP_GLOBAL_EVENTS=
AMQP_SPECIFIC_EVENTS=
NATS_URL=
NATS_GLOBAL_ENABLED=false
NATS_GLOBAL_EVENTS=
EVENT_IGNORE_GROUP=false
EVENT_IGNORE_STATUS=false

MINIO_ENABLED=false
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_USE_SSL=false
MINIO_REGION=

API_AUDIO_CONVERTER=
API_AUDIO_CONVERTER_KEY=
QRCODE_MAX_COUNT=5
CHECK_USER_EXISTS=true

PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

WHATSAPP_VERSION_MAJOR=
WHATSAPP_VERSION_MINOR=
WHATSAPP_VERSION_PATCH=
RESET_ADMIN_PASSWORD=false
